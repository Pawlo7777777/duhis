<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Bottom Sheet Dialog Theme (for bottom sheets) -->
    <style name="Theme_DUHIS_Dialog" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/Widget.MaterialComponents.BottomSheet.Modal</item>
    </style>

    <!-- Alert Dialog Theme (for confirmation dialogs) -->
    <style name="Theme_DUHIS_AlertDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_color</item>
        <item name="colorAccent">@color/primary_color</item>
        <item name="android:colorPrimary">@color/primary_color</item>
        <item name="android:colorPrimaryDark">@color/primary_color</item>
        <item name="android:colorAccent">@color/primary_color</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <!-- Alternative: If you want a custom dialog with rounded corners -->
    <style name="Theme_DUHIS_RoundedDialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorAccent">@color/primary_color</item>
        <item name="android:colorPrimary">@color/primary_color</item>
        <item name="android:colorAccent">@color/primary_color</item>
    </style>

</resources>