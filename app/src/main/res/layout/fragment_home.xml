<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="MissingDefaultResource">

    <!-- ======================== MAIN CONTENT ======================== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_color"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Hero / Header Banner ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/duhis_green_dark"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="32dp">

                    <!-- Hamburger Menu Button -->
                    <ImageButton
                        android:id="@+id/btnDrawerToggle"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|start"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_hamburger"
                        android:contentDescription="Open menu"
                        app:tint="@color/black" />

                    <!-- Notification Bell -->
                    <ImageButton
                        android:id="@+id/btnNotifications"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_notification"
                        android:contentDescription="Notifications"
                        app:tint="@color/black" />

                    <!-- Greeting Text — centered below the icons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="56dp"
                        android:orientation="vertical"
                        android:gravity="start">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good Morning,"
                            android:textSize="15sp"
                            android:letterSpacing="0.05"
                            android:textColor="#BBFFFFFF" />

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Name"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How can we help you today?"
                            android:textSize="13sp"
                            android:textColor="#AAFFFFFF"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Curved white overlap card that peeks over the green banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_dialog_rounded"
                    android:layout_marginTop="-20dp"
                    android:paddingTop="24dp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="24dp">

                    <!-- ── Quick Actions Label ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Actions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03"
                        android:textColor="@color/text_primary_color"
                        android:layout_marginBottom="14dp" />

                    <!-- ── Quick Action Cards Row 1 ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <!-- Appointment -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardAppointment"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F0FAF4">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:padding="18dp">

                                <FrameLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp">
                                    <ImageView
                                        android:layout_width="26dp"
                                        android:layout_height="26dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@color/duhis_green" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Appointment"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Book a visit"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Health Info -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardHealthInfo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F0F4FA">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:padding="18dp">

                                <FrameLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp">
                                    <ImageView
                                        android:layout_width="26dp"
                                        android:layout_height="26dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_health"
                                        app:tint="@color/primary_color" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Health Info"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Learn &amp; explore"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- ── Quick Action Cards Row 2 ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="28dp">

                        <!-- Emergency -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardEmergency"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/duhis_red">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:padding="18dp">

                                <FrameLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:background="@color/duhis_red">
                                    <ImageView
                                        android:layout_width="26dp"
                                        android:layout_height="26dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_emergency"
                                        app:tint="@color/white" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Emergency"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:gravity="center"
                                    android:layout_marginTop="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Get help now"
                                    android:textSize="11sp"
                                    android:textColor="#CCFFFFFF"
                                    android:gravity="center"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Notifications -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardNotifications"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFF8F0">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:padding="18dp">

                                <FrameLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp">
                                    <ImageView
                                        android:layout_width="26dp"
                                        android:layout_height="26dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_notification"
                                        app:tint="#E67E22" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Notifications"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="10dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Stay updated"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_color"
                                    android:gravity="center"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- ── Featured Health Information ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Featured Health Info"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.03"
                            android:textColor="@color/text_primary_color" />

                        <TextView
                            android:id="@+id/tvSeeAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See all"
                            android:textSize="13sp"
                            android:textColor="@color/duhis_green"
                            android:textStyle="bold"
                            android:padding="4dp" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFeatured"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ======================== NAVIGATION DRAWER ======================== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header_home"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/duhis_green"
        app:itemTextColor="@color/text_primary_color"
        app:itemRippleColor="@color/duhis_green" />

</androidx.drawerlayout.widget.DrawerLayout>